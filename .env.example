# GitHub OAuth
# Create an OAuth app at https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Allowed GitHub user IDs (numeric). Comma-separate multiple values.
# How to check: https://api.github.com/users/<your_username>
ALLOWED_GITHUB_USER_IDS=

# Secret for signing sessions (a long random string)
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# HMAC shared key between the Local Agent and the Backend
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
AGENT_HMAC_SECRET=

# App URL (Tailscale hostname or IP)
# e.g. https://<machine>.<tailnet>.ts.net
APP_BASE_URL=

# GitHub OAuth callback URL
# e.g. https://<machine>.<tailnet>.ts.net/auth/github/callback
GITHUB_CALLBACK_URL=
