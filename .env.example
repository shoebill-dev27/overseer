# GitHub OAuth
# https://github.com/settings/developers でOAuthアプリを作成
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# 許可するGitHub User ID（数値）。複数の場合はカンマ区切り
# 確認方法: https://api.github.com/users/<your_username>
ALLOWED_GITHUB_USER_IDS=

# セッション署名用シークレット（ランダムな長い文字列）
# 生成: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Local Agent ↔ Backend 間のHMAC共有鍵
# 生成: python3 -c "import secrets; print(secrets.token_hex(32))"
AGENT_HMAC_SECRET=

# アプリURL（Tailscale IP or hostname）
# 例: http://100.91.114.83
APP_BASE_URL=

# GitHub OAuthコールバックURL
# 例: http://100.91.114.83:8000/auth/github/callback
GITHUB_CALLBACK_URL=
