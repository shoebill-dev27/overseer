# ── Local Agent environment variable template ────────────────────────────────
# Copy this file to agent/.env and fill in real values.
#   cp agent/.env.example agent/.env
# .env is gitignored. Never commit real values.

# ── Required ──────────────────────────────────────────────────────────────────
# Must match AGENT_HMAC_SECRET in backend/.env exactly (startup is FAILED if unset).
AGENT_HMAC_SECRET=

# ── Optional (have defaults) ──────────────────────────────────────────────────
# Backend Internal API URL. Assumed to be on localhost.
# Distinct from backend.url in config/agent.yaml; the communication URL uses this var.
BACKEND_URL=http://127.0.0.1:8000
# Internal API request timeout (seconds).
AGENT_REQUEST_TIMEOUT=5
