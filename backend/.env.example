# ── Backend 環境変数テンプレート ──────────────────────────────────────────────
# このファイルをコピーして backend/.env を作成し、実値を入れる。
#   cp backend/.env.example backend/.env
# .env は .gitignore 済み。実値は絶対にコミットしないこと。

# ── 必須シークレット（未設定だと起動が FAILED で停止する）─────────────────────
# サーバ用シークレット。現状は起動時の存在チェックのみ（将来のCookie署名用に予約）。
# 生成例: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# Local Agent との Internal API 通信を認証する HMAC 共有シークレット。
# agent/.env の AGENT_HMAC_SECRET と完全に一致させること。
# 生成例: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
AGENT_HMAC_SECRET=

# ── GitHub OAuth（ログインに必須。未設定だと起動は DEGRADED でログイン不可）──
# GitHub の OAuth App (Settings > Developer settings > OAuth Apps) で発行する。
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# OAuth App の Authorization callback URL と完全一致させる。
GITHUB_CALLBACK_URL=http://127.0.0.1:8000/auth/github/callback

# ── アクセス制御 ──────────────────────────────────────────────────────────────
# ログインを許可する GitHub の「数値ユーザーID」（username ではない）をカンマ区切りで列挙。
# 自分のIDの調べ方: curl https://api.github.com/users/<username> | grep '"id"'
# 初回ログイン時は VIEWER ロールで作成される。昇格はDBを直接更新する。
ALLOWED_GITHUB_USER_IDS=

# ── 任意（デフォルトあり）─────────────────────────────────────────────────────
# CORS 許可オリジン。フロントを別ポートで開発する場合のみ変更。
APP_BASE_URL=http://127.0.0.1:8000
# SQLite ファイルのパス（backend/ からの相対）。
DATABASE_PATH=overseer.db
