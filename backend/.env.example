# ── Backend environment variable template ────────────────────────────────────
# Copy this file to backend/.env and fill in real values.
#   cp backend/.env.example backend/.env
# .env is gitignored. Never commit real values.

# ── Required secrets (startup stops with FAILED if unset) ─────────────────────
# Server secret. Currently only existence-checked at startup (reserved for future
# cookie signing).
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# HMAC shared secret authenticating Internal API traffic with the Local Agent.
# Must match AGENT_HMAC_SECRET in agent/.env exactly.
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
AGENT_HMAC_SECRET=

# ── GitHub OAuth (required for login; startup is DEGRADED and login fails if unset) ──
# Issue these in a GitHub OAuth App (Settings > Developer settings > OAuth Apps).
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Must match the OAuth App's Authorization callback URL exactly.
GITHUB_CALLBACK_URL=http://127.0.0.1:8000/auth/github/callback

# ── Access control ────────────────────────────────────────────────────────────
# Comma-separated list of allowed GitHub "numeric user IDs" (not usernames).
# How to find your ID: curl https://api.github.com/users/<username> | grep '"id"'
# First login creates the user with the VIEWER role. Promote by updating the DB directly.
ALLOWED_GITHUB_USER_IDS=

# ── Optional (have defaults) ──────────────────────────────────────────────────
# Allowed CORS origin. Change only if developing the frontend on a different port.
APP_BASE_URL=http://127.0.0.1:8000
# Path to the SQLite file (relative to backend/).
DATABASE_PATH=overseer.db
